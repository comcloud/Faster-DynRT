{
  "info": {
    "name": "DynRT",
    "log": {
      "name": ""
    },
    "device": [
      0
    ],
    "test_on_checkpoint": "none",
    "train_on_checkpoint": "none"
  },
  "opt": {
    "seed": 2,
    "dataloader": {
      "requires": {
        "tokenizer_roberta": {
          "path": "/root/autodl-tmp/ray/pretrained/models/roberta"
        },
        "tokenizer_albert": {
          "path": "/root/autodl-tmp/ray/pretrained/models/albert"
        },
        "tokenizer_bert": {
          "path": "/root/autodl-tmp/ray/pretrained/models/bert"
        },
        "tokenizer_xlnet": {
          "path": "/root/autodl-tmp/ray/pretrained/models/xlnet"
        },
        "tokenizer": "tokenizer_roberta"
      },
      "loaders": {
        "text": {
          "source": "prepared",
          "data_path": "input/prepared_aligned/",
          "data_2_path": "input/MSD2/",
          "data_bully_path": "input/bully/",
          "len": 100,
          "pad": 1,
          "att_file_path": "input/prepared_aligned/att/",
          "mould": "A photo containing the {att_0}, {att_1}, {att_2}, {att_3} and {att_4}"
        },
        "img": {
          "source": "prepared",
          "data_path": "input/prepared_aligned/",
          "data_2_path": "input/MSD2/",
          "data_bully_path": "input/bully/",
          "transform_image": "/root/autodl-tmp/ray/data/datasets/msd/tensor/",
          "image_root": "/root/autodl-tmp/ray/data/datasets/msd/images/imageVector2/",
          "image_resize": 224
        },
        "label": {
          "source": "prepared",
          "data_path": "input/prepared_aligned/",
          "data_2_path": "input/MSD2/",
          "data_bully_path": "input/bully/",
          "test_label": true
        }
      },
      "batch_size": 32,
      "pin_memory": true,
      "num_workers": 0,
      "shuffle": true
    },
    "mode": [
      "train",
      "valid",
      "test"
    ],
    "checkpoint_step": 50,
    "modelopt": {
      "name": "DynRT",
      "input1": "text",
      "input2": "img",
      "input3": "text_mask",
      "input4": "att",
      "input5": "att_mask",
      "layer": 4,
      "tau_max": 10,
      "ORDERS": [
        0,
        1,
        2,
        3
      ],
      "IMG_SCALE": 7,
      "dropout": 0.5,
      "hidden_size": 768,
      "ffn_size": 768,
      "multihead": 2,
      "routing": "hard",
      "BINARIZE": false,
      "len": 100,
      "glimpses": 1,
      "mlp_size": 768,
      "output_size": 768,
      "orders": 4,
      "pooling": "avg",
      "classifier": "both",
      "model": "model_roberta",
      "model_roberta": "/root/autodl-tmp/ray/pretrained/models/roberta",
      "vit_path": "/root/autodl-tmp/ray/pretrained/models/vit",
      "model_albert": "/root/autodl-tmp/ray/pretrained/models/albert",
      "model_bert": "/root/autodl-tmp/ray/pretrained/models/bert",
      "model_xlnet": "/root/autodl-tmp/ray/pretrained/models/xlnet",
      "roberta_layer": 1,
      "vitmodel": "vit_base_patch32_224",
      "finetune": false
    },
    "optimizeropt": {
      "name": "Adam",
      "lr": 1e-06,
      "weight_decay": 0.01,
      "params": {
        "bertl_text": {
          "lr": 3e-07
        },
        "vit": {
          "lr": 3e-07,
          "weight_decay": 0.01
        },
        "trar": {
          "lr": 2e-05,
          "weight_decay": 0.01
        },
        "bridge_info_layer.image_biaff_trans": {
          "lr": 3e-04,
          "weight_decay": 0.01
        },
        "bridge_info_layer.dynamic_net": {
          "lr": 1e-04,
          "weight_decay": 0.01
        },
        "cross_modal_transformer_layer": {
          "lr": 1e-04,
          "weight_decay": 0.01
        },
        "classifier": {
          "lr": 3e-04,
          "weight_decay": 0.01
        }
      }
    },
    "lossopt": {
      "name": "LabelSmoothCrossEntropyLoss"
    },
    "total_epoch": 15,
    "clip": 10
  }
}
